{
  "name": "recast",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "app",
    "website"
  ],
  "scripts": {
    "dev:app": "npm run dev -w recast-app",
    "dev:website": "npm run dev -w recast-website",
    "build:app": "npm run build -w recast-app",
    "build:website": "npm run build -w recast-website",
    "lint": "npm run lint -w recast-app && npm run lint -w recast-website",
    "electron:dev": "npm run electron:dev -w recast-app",
    "electron:build": "npm run electron:build -w recast-app",
    "electron:preview": "npm run electron:preview -w recast-app",
    "electron:start": "npm run electron:start -w recast-app"
  }
}
